# Copy to .env and fill in. .env is gitignored — never commit real creds.
# TP-Link / Tapo cloud account credentials (used for LOCAL KLAP auth, not cloud control).
# Device IPs are NOT stored — every command discovers devices live (see TAPO_SUBNET).
TAPO_USERNAME=you@example.com
TAPO_PASSWORD=your-tapo-account-password

# Subnet (CIDR) to UNICAST-SCAN for devices. REQUIRED for the DOCKER container
# (broadcast can't cross the bridge; unicast can). Every command discovers devices
# in memory from this subnet — nothing is written to disk. Leave blank only when
# running on the host / host networking, where broadcast discovery works.
# A bare network address (no /prefix) is treated as a /24.
# TAPO_SUBNET=192.168.1.0/24   # your LAN subnet (254 hosts for a /24)

# ClickHouse — required for `migrate` and for `monitor` (writes power readings).
# Only CLICKHOUSE_HOST is mandatory; the rest fall back to these defaults.
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=false

# docker-compose monitor parameters (the service runs `monitor` on startup).
# In compose, CLICKHOUSE_HOST is overridden to 127.0.0.1 automatically.
MONITOR_DEVICES=all   # which devices: name(s)/id prefix(es) space-separated, or 'all'
MONITOR_INTERVAL=30  # window seconds — one MEAN row per window per device
MONITOR_SAMPLE=5      # seconds between samples within a window
