# Copy to docker-compose.yml, then edit freely — container_name included.
# The scripts read each container_name out of THIS file, so renaming a
# container_name is fine (just keep one). What you must NOT rename are the
# SERVICE KEYS the scripts anchor on, or scripts/start.sh, scripts/stop.sh,
# scripts/connect-to-db.sh, scripts/main.sh break:
#   - service key `tapo-clickhouse`     (connect-to-db.sh reads its container_name)
#   - service key `tapo-observability`  (main.sh reads its container_name; start.sh tails its logs)
#   - `CLICKHOUSE_HOST` must equal the clickhouse service name (`tapo-clickhouse`)
# Everything else (image tag, ports, ulimits, volumes, container_name, env) is safe.

# Cap container logs so the monitor's per-sample output can't fill the disk.
# 5 files x 10MB = 50MB max per container, oldest rotated out.
x-logging: &default-logging
  driver: "json-file"
  options:
    max-size: "10m"
    max-file: "5"

services:
  tapo-clickhouse:                             # [scripts] don't rename this SERVICE KEY — connect-to-db.sh anchors on it
    image: clickhouse/clickhouse-server:26.3
    container_name: tapo-clickhouse            # editable — connect-to-db.sh reads this value to exec the container
    logging: *default-logging
    environment:
      CLICKHOUSE_SKIP_USER_SETUP: "1"
    ports:
      # Published so you can run `discover --save` (and ad-hoc queries) from the
      # HOST against the same DB at localhost:8123.
      - "8123:8123"
      - "9000:9000"
    volumes:
      - tapo_clickhouse_data:/var/lib/clickhouse
      # Disable system.*_log tables + cap text log (see file for details).
      # Mount the single file (NOT the whole config.d dir) so the image's
      # docker_related_config.xml — which sets listen_host — stays in place.
      - ./clickhouse/config.d/logging.xml:/etc/clickhouse-server/config.d/logging.xml:ro
    ulimits:
      nofile:
        soft: 262144
        hard: 262144
    healthcheck:
      test: ["CMD", "clickhouse-client", "--query", "SELECT 1"]
      interval: 5s
      timeout: 3s
      retries: 20

  tapo-observability:                          # [scripts] don't rename this SERVICE KEY — start.sh/main.sh anchor on it
    build: .
    container_name: tapo-observability         # editable — main.sh reads this value to exec the container
    logging: *default-logging
    # Bridge networking (default). The app reaches ClickHouse by service name and
    # reaches Tapo devices by unicast IP (the host NATs container -> LAN), so
    # monitor/status/on/off all work without host networking.
    #
    # The ONE thing a bridge can't do is DISCOVERY (UDP broadcast to the LAN).
    # Run discovery on the HOST instead — it writes ./local/devices.json (mounted
    # below) and, with ClickHouse up, the device/device_snapshot tables:
    #     uv run python main.py discover --save
    env_file:
      - .env
    environment:
      CLICKHOUSE_HOST: tapo-clickhouse     # [scripts] must equal the clickhouse service name above
      CLICKHOUSE_PORT: "8123"
      # monitor's two parameters (see scripts/entrypoint.sh):
      MONITOR_DEVICES: "${MONITOR_DEVICES:-all}"   # which devices: name(s)/id prefix(es)/all
      MONITOR_INTERVAL: "${MONITOR_INTERVAL:-300}" # window seconds (mean per window)
      MONITOR_SAMPLE: "${MONITOR_SAMPLE:-5}"       # sample seconds within the window
    volumes:
      - ./local:/app/local       # registry (devices.json) — populated by host discovery
    depends_on:
      tapo-clickhouse:
        condition: service_healthy
    restart: unless-stopped

volumes:
  tapo_clickhouse_data:
